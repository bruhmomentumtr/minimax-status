{
  "name": "minimax-status-vscode",
  "displayName": "MiniMax Status",
  "description": "Display MiniMax Token-Plan usage status in VS Code status bar",
  "version": "1.3.3",
  "publisher": "JochenYang",
  "icon": "./public/icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:mmaximaxStatusView"
  ],
  "contributes": {
    "commands": [
      {
        "command": "minimaxStatus.setup",
        "title": "MiniMax Status: Configuration Wizard",
        "category": "MiniMax",
        "description": "Configure MiniMax access token"
      },
      {
        "command": "minimaxStatus.refresh",
        "title": "MiniMax Status: Refresh Status",
        "category": "MiniMax",
        "description": "Manually refresh MiniMax status"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "minimaxStatusSidebar",
          "title": "MiniMax Status",
          "icon": "public/icon.png"
        }
      ]
    },
    "views": {
      "minimaxStatusSidebar": [
        {
          "id": "minimaxStatusView",
          "name": "Settings"
        }
      ]
    },
    "configuration": {
      "title": "MiniMax Status",
      "properties": {
        "minimaxStatus.token": {
          "type": "string",
          "default": "",
          "description": "MiniMax access token",
          "order": 1
        },
        "minimaxStatus.groupId": {
          "type": "string",
          "default": "",
          "description": "MiniMax group ID",
          "order": 2
        },
        "minimaxStatus.refreshInterval": {
          "type": "number",
          "default": 30,
          "description": "Refresh interval (seconds)",
          "order": 3
        },
        "minimaxStatus.showTooltip": {
          "type": "boolean",
          "default": true,
          "description": "Show detailed tooltip",
          "order": 4
        },
        "minimaxStatus.modelName": {
          "type": "string",
          "default": "",
          "description": "Model to display (leave empty for first model)",
          "order": 5
        },
        "minimaxStatus.language": {
          "type": "string",
          "default": "en-US",
          "description": "Language (en-US, tr-TR)",
          "order": 6
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js",
    "package": "vsce package",
    "install-test": "npm install"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^2.21.0",
    "eslint": "^8.56.0",
    "mocha": "^11.7.5"
  },
  "dependencies": {
    "axios": "^1.6.2"
  },
  "keywords": [
    "minimax",
    "status",
    "claude"
  ],
  "author": "Jochen Yang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JochenYang/minimax-status"
  }
}
